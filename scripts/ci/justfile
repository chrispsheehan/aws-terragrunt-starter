# Check the fixed ECS images exist for the requested version.
ecs-check-deploy-images:
    #!/usr/bin/env bash
    set -euo pipefail

    if [[ -z "${ECR_REPOSITORY_URL:-}" ]]; then
        echo "❌ ECR_REPOSITORY_URL environment variable is not set."
        exit 1
    fi

    if [[ -z "${VERSION:-}" ]]; then
        echo "❌ VERSION environment variable is not set."
        exit 1
    fi

    repository_name="${ECR_REPOSITORY_URL#*/}"

    for image in worker debug; do
        tag="$image-$VERSION"
        aws ecr describe-images \
          --repository-name "$repository_name" \
          --image-ids "imageTag=$tag" >/dev/null \
          && echo "✅ $tag found" \
          || (echo "❌ $tag not found in $ECR_REPOSITORY_URL" && exit 1)
    done


# Discover repo-local Docker-based GitHub action directories.
action-get-directories:
    #!/usr/bin/env bash
    set -euo pipefail

    find "{{PROJECT_DIR}}/.github/actions" -mindepth 1 -maxdepth 1 -type d \
      | while read -r dir; do
          if [[ -f "$dir/Dockerfile" ]]; then
            basename "$dir"
          fi
        done \
      | sort \
      | jq -R . \
      | jq -s -c .
